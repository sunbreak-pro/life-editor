# IDE
.idea/
*.iml
.vscode/
.DS_Store

# Claude Code worktrees
.claude/worktrees/

# Claude HTML report views (derived, not tracked — md plans remain SSOT)
.claude/reports/

# Logs
*.log

# Node (root)
/node_modules/

# Web-first migration (Phase 1: web/ + shared/ + supabase/)
web/node_modules/
web/dist/
shared/node_modules/
shared/dist/
supabase/node_modules/

# Mobile UI prototype env (Vite, isolated from frontend/)
prototype/node_modules/
prototype/dist/

# Per-chat session identity & runtime state (FileChanged plan + per-chat MEMORY plan で共有)
.claude/comm/.session-name
.claude/comm/.watch-state/
.claude/comm/.inbox-pending.md
.claude/scheduled_tasks.lock

# Hook-generated outbox reports (per-session 動的データ; chat-*.md は task-tracker 経由
# 人手管理なので追跡を維持。session-start-check.sh / stop-check.sh が吐く reports のみ無視)
.claude/comm/outbox/*/session-start-warnings.md
.claude/comm/outbox/*/stop-report.md

# Hook-generated outbox reports (per-session 動的データ; chat-*.md は task-tracker 経由
# 人手管理なので追跡を維持。session-start-check.sh / stop-check.sh が吐く reports のみ無視)
.claude/comm/outbox/*/session-start-warnings.md
.claude/comm/outbox/*/stop-report.md

# Supabase CLI local state (never commit: link state, branch state, env)
# supabase/.env holds SUPABASE_DB_URL (DB password). Defence-in-depth:
# (1) this ignore rule, (2) check-rls.sh never `source`s it (extracts only
# the SUPABASE_DB_URL line), (3) error output is DSN-masked. Do not remove
# any single layer assuming the others cover it.
supabase/.temp/
supabase/.branches/
supabase/.env

# Secrets — never commit env files (incl. Supabase anon key)
.env
.env.local
.env.*.local
**/.env.local
**/.env.*.local

# MCP Server
mcp-server/dist/
mcp-server/node_modules/

# Cloud (Cloudflare Workers)
cloud/node_modules/
cloud/.wrangler/

# Tauri
src-tauri/target/
src-tauri/gen/
